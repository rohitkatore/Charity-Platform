# ============================================================
# Golf Charity Subscription Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# ── General ──
NODE_ENV=production
API_PORT=4000

# ── Database Provider ──
# sqlite (default, current app storage) or supabase (credentials ready for migration/deploy)
DATABASE_PROVIDER=sqlite

# Supabase project configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional direct DB URL (for future Postgres client migration)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# ── CORS ──
# Comma-separated list of allowed origins
CORS_ORIGIN=https://your-app.vercel.app

# ── Authentication ──
JWT_SECRET=your-strong-random-secret-here-min-32-chars
JWT_COOKIE_NAME=gcs_auth
JWT_COOKIE_SAME_SITE=lax
JWT_COOKIE_DOMAIN=
JWT_TTL=8h
SECURE_COOKIES=true

# ── Admin Seed ──
# Set to true ONLY for first deploy to create admin account, then disable.
AUTO_SEED_ADMIN=true
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=YourStrongAdminPassword123!

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_CURRENCY=gbp

# ── App URLs ──
APP_BASE_URL=https://your-app.vercel.app

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── Frontend (prefix with VITE_ for Vite) ──
VITE_API_BASE_URL=https://your-app.vercel.app/api
